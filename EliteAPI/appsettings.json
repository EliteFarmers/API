{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
      "Microsoft.AspNetCore.Diagnostics.ExceptionHandlerMiddleware": "None",
      "System.Net.Http.HttpClient.Refit": "Warning",
      "Polly": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Pyroscope": {
    "ServerAddress": "http://localhost:4040",
    "ApplicationName": "eliteapi",
    "ProfilingEnabled": false
  },
  "ConnectionStrings": {
    "Postgres": "Server=localhost;Port=5436;Database=eliteapi;Username=user;Password=postgres123;Include Error Detail=true",
    "Redis": "localhost:6380,password=redis123"
  },
  "MinecraftRenderer": {
    "AcceptEula": true,
    "Version": "1.21.9",
    "AssetsPath": ""
  },
  "Messaging": {
    "ErrorAlertServer": "",
    "ErrorAlertChannel": "",
    "ErrorAlertPing": "",
    "WipeServer": "",
    "WipeChannel": "",
    "AuditLogServer": "",
    "AuditLogChannel": ""
  },
  "Jwt": {
    "Secret": "local-dev-jwt-secret-change-if-shared",
    "Issuer": "eliteapi",
    "Audience": "eliteapi",
    "TokenExpirationInMinutes": 60,
    "RefreshTokenExpirationInDays": 30
  },
  "WebsiteSecret": "local-website-secret",
  "S3": {
    "AccessKey": "",
    "SecretKey": "",
    "BucketName": "",
    "Endpoint": "",
    "PublicUrl": "",
    "UseForTextures": false
  },
  "Discord": {
    "ClientId": "",
    "ClientSecret": "",
    "BotToken": "",
    "BaseUrl": "https://discord.com/api/v10"
  },
  "Hypixel": {
    "ApiKey": "",
    "BaseUrl": "https://api.hypixel.net/",
    "RequestLimit": 60
  },
  "Leaderboards": {
    "BatchIntervalSeconds": 5,
    "MaxBatchSize": 1000,
    "QueueCapacity": 10000,
    "EnableAsyncUpdates": true,
    "CompleteRefreshInterval": 15
  },
  "ApiRateLimit": {
    "PermitLimit": 6,
    "Window": 9,
    "ReplenishmentPeriod": 1,
    "QueueLimit": 2,
    "SegmentsPerWindow": 4,
    "TokenLimit": 8,
    "TokenLimit2": 12,
    "TokensPerPeriod": 4,
    "AutoReplenishment": true
  },
  "GlobalRateLimit": {
    "ReplenishmentPeriod": 10,
    "QueueLimit": 20,
    "TokenLimit": 20,
    "TokensPerPeriod": 5,
    "AutoReplenishment": true
  },
  "SuperUser": {
    "Email": "Admin",
    "Password": "Admin"
  },
  "Seed": {
    "AdminUserId": ""
  },
  "Authentication": {
    "DefaultScheme": "LocalAuthIssuer",
    "Schemes": {
      "Bearer": {
        "ValidAudiences": ["https://localhost:7259", "http://localhost:5259"],
        "ValidIssuer": "dotnet-user-jwts"
      },
      "LocalAuthIssuer": {
        "ValidAudiences": ["https://localhost:7259", "http://localhost:5259"],
        "ValidIssuer": "local-auth"
      }
    }
  },
  "SetupDiagnostics": {
    "LogProfileRequests": false,
    "LogWebsiteSecretBypass": true,
    "PathPrefixes": ["/profiles", "/account", "/auth", "/guilds"]
  }
}
